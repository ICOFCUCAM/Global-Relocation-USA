# ─────────────────────────────────────────────────────────────────────────────
# FlyttGo USA — Environment Variables Template
#
# LOCAL:  copy this file to .env.local and fill in real values.
# VERCEL: add the same variables under Project → Settings → Environment
#         Variables. Because the Vercel–Supabase integration is enabled,
#         these should be sourced from the linked Supabase project so the
#         deployed site always talks to the same database as GitHub CI.
#
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (required)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Maps (required for address autocomplete in HomePage)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Stripe (optional — only needed if Stripe checkout is live)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
